# Multimodal Semantic Image-Text Retrieval - Environment
# Copy to .env and adjust as needed

RETRIEVAL_API_HOST=0.0.0.0
RETRIEVAL_API_PORT=8000
RETRIEVAL_API_PREFIX=/api/v1

# ChromaDB persistence
RETRIEVAL_CHROMA_PERSIST_DIR=./data/chroma
RETRIEVAL_CHROMA_COLLECTION_NAME=image_embeddings

# CLIP model (ViT-B-32 + openai weights by default)
RETRIEVAL_CLIP_MODEL_NAME=ViT-B-32
RETRIEVAL_CLIP_PRETRAINED=openai

# Limits
RETRIEVAL_MAX_IMAGE_SIZE_MB=10
RETRIEVAL_MAX_TOP_K=100
RETRIEVAL_DEFAULT_TOP_K=10
